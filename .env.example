# Saaphzone Technologies — Environment Variables
# Copy this file to .env.local and fill in your values

# Site URL (used for OG image base URL, sitemaps, etc.)
NEXT_PUBLIC_SITE_URL=https://www.saaphzone.com

# Contact Form (if using a backend email service — e.g. Resend, SendGrid, Nodemailer)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# CONTACT_FORM_TO_EMAIL=info@saaphzone.com

# Google Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps API Key (optional, for embedded map on Contact page)
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSyXXXXXXXXXXXXXXXXX
